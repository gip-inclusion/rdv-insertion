<div class="mb-4 background-blue-paler p-4 rounded-3">
  <h3 class="h5 mb-2 fw-bold text-dark-blue">Motifs de rendez-vous</h3>

  <% if motifs.any? %>
    <div class="table-responsive mx-3 mb-4">
      <table class="table">
        <thead>
          <tr>
            <th>Nom du motif</th>
            <th>Type de rendez-vous</th>
            <th>Durée</th>
            <th>Invitations</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody class="border-top-0">
          <% motifs.each do |motif| %>
            <tr>
              <td><%= motif.name %></td>
              <td><%= I18n.t("activerecord.attributes.motif.location_types.#{motif.location_type}") %></td>
              <td><%= motif.default_duration_in_min %> min</td>
              <td><%= motif.bookable_by_invited_users? ? "oui" : "non" %></td>
              <td>
                <%= link_to rdv_solidarites_edit_motif_url(organisation, motif),
                            target: "_blank",
                            class: "text-decoration-none" do %>
                  <i class="ri-pencil-fill me-1"></i>
                  <span class="text-decoration-underline">Modifier</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="d-flex flex-column align-items-center text-center py-4 gap-3">
      <%= image_tag "illustrations/empty-results.png", alt: "", width: 120 %>
      <div>
        <p class="mb-2">Il n'y a pas encore de motifs rattachés à cette catégorie.</p>
        <p class="text-muted small mb-0">
          Pour commencer à ajouter et inviter des usagers sur cette catégorie,
          <%= link_to rdv_solidarites_motifs_url(organisation), target: "_blank", class: "text-decoration-underline" do %>
            rattachez des motifs de rendez-vous
          <% end %>
          <i class="ri-external-link-line text-primary"></i>.
        </p>
      </div>
    </div>
  <% end %>

  <div class="d-flex justify-content-end gap-2 mt-3">
    <%= link_to rdv_solidarites_motifs_url(organisation),
                target: "_blank",
                class: "btn btn-blue-out" do %>
      Consulter les motifs <i class="ri-external-link-line ms-1"></i>
    <% end %>
    <%= link_to rdv_solidarites_new_motif_url(organisation),
                target: "_blank",
                class: "btn btn-blue" do %>
      <i class="ri-add-line me-1"></i> Ajouter un motif
    <% end %>
  </div>
</div>
