<div id="<%= dom_id(category_configuration) %>" class="card-white mb-3">
  <div class="clickable d-flex justify-content-between align-items-center"
       data-action="click->accordion#toggle"
       data-index="<%= index %>"
       role="button"
       aria-expanded="false">
    <div>
      <span class="fw-bold h5">« <%= category_configuration.motif_category_name %> »</span>
      <% if motifs.empty? %>
        <span class="text-muted ms-2"> - </span><span class="text-dark-red ms-2">0 motif</span>
      <% else %>
        <span class="text-muted ms-2"> - </span><span class="text-muted ms-2"><%= motifs.size %> <%= "motif".pluralize(motifs.size) %> <%= "rattaché".pluralize(motifs.size) %></span>
      <% end %>
    </div>
    <div class="d-flex align-items-center gap-3">
      <% if motifs.empty? %>
        <%= link_to rdv_solidarites_motifs_url(organisation), target: "_blank" do %>
          <i class="ri-add-fill"></i><span class="text-decoration-underline">Rattacher des motifs</span>
        <% end %>
      <% end %>
      <i class="ri-arrow-down-s-line fs-4" data-accordion-target="icon"></i>
    </div>
  </div>

  <div class="d-none" data-accordion-target="content">
    <%= render "organisations/category_configurations/accordion_content",
               category_configuration: category_configuration,
               motifs: motifs,
               organisation: organisation %>
  </div>
</div>
