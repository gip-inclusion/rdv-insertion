<div class="col-md-10">
  <table class="user-list-upload-table">
    <thead class="bg-white text-dark-blue" data-controller="sort-list">
      <tr>
        <th scope="col" class="border-light">
          <input type="checkbox" class="form-check-input" id="selectAll" checked>
        </th>
        <th scope="col" class="border-light">Civilité</th>
        <th scope="col" data-action="click->sort-list#changeUrlParams" data-sort-by="first_name">
          Prénom <i class="ri-arrow-up-down-line" role="button"></i>
        </th>
        <th scope="col" data-action="click->sort-list#changeUrlParams" data-sort-by="last_name">
          Nom <i class="ri-arrow-up-down-line" role="button"></i>
        </th>
        <th scope="col" class="border-light">Numéro CAF</th>
        <th scope="col" class="border-light">Téléphone</th>
        <th scope="col" class="border-light">Email</th>
        <th scope="col" class="border-light" data-action="click->sort-list#changeUrlParams" data-sort-by="status">
          Statut du dossier <i class="ri-arrow-up-down-line" role="button"></i>
        </th>
      </tr>
    </thead>
    <tbody>
      <% user_rows.each do |user_row| %>
        <tr class="bg-light">
          <td class="border-light">
            <input type="checkbox" class="form-check-input user-checkbox" value="<%= user_row.uid %>" checked>
          </td>
          <% [:title, :first_name, :last_name, :affiliation_number, :phone_number, :email].each do |attribute| %>
            <td class="border-light <%= background_color_for_attribute(user_row, attribute) %>"
                data-controller="user-row-cell"
                data-action="dblclick->user-row-cell#toggle">
              <div class="d-flex justify-content-between"
                   data-user-row-cell-target="show"
                   data-action="dblclick->user-row-cell#edit">
                <span><%= display_attribute(user_row.send(attribute)) %></span>
                <%= icon_for_attribute(user_row, attribute) %>
              </div>
              <div class="d-none" data-user-row-cell-target="edit">
                <%= render "edit_row_attribute", user_row: user_row, attribute: attribute %>
              </div>
            </td>
          <% end %>
          <td class="border-light <%= background_color_for_attribute(user_row, :status) %>">
            <div class="d-flex justify-content-between align-items-center">
              <span class="badge rounded-pill <%= user_status_badge_class(user_row.status) %>">
                <%= user_status_text(user_row.status) %>
              </span>
              <% if user_row.matching_user_id %>
                <%= link_to structure_user_path(id: user_row.matching_user_id), target: "_blank" do %>
                  <i class="ri-external-link-line text-dark-blue"></i>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>