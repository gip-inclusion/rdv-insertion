<% content_for :title, "Données usagers chargées - #{current_structure_name_with_context} - rdv-insertion" %>
<%# The body is different from the others because it has a light blue background, but it will soon be the norm in the whole app.
When it will be the norm, we will remove the content_for :body_class declaration. %>
<% content_for :body_class, "bg-white" %>

<div class="container px-5 py-3">
  <div class="row text-dark-blue ">
    <div class="col text-center align-items-center my-1">
      <div>
        <h1 class="h1-title">Données usagers chargées</h1>
        <p class="text-muted mb-4">au niveau de « <%= current_structure_name_with_context %> »<%= ", sur « #{@category_configuration.motif_category.name} »" if @category_configuration %></p>
      </div>
    </div>
  </div>

  <%= turbo_frame_tag "user_collection", data: { turbo_action: "advance" } do %>
    <div class="row justify-content-center">
      <div class="col-md-10">
        <div class="mb-4">
          <h2 class="h2-title">Vérifiez et complétez les données usagers</h2>
          <p class="text-muted">
            Données du fichier « <%= @user_list_upload.file_name %> ». Vous pouvez enrichir ces données avec celles du fichier CNAF.
          </p>
        </div>

        <div class="d-flex border-bottom align-items-center">
          <ul class="nav nav-tabs flex-grow-1 border-bottom-0 align-self-end">
            <li class="nav-item">
              <%= link_to structure_user_list_upload_path(id: @user_list_upload.id), class: "nav-link #{user_with_errors? ? 'text-light-blue' : 'active text-dark-blue fw-bold' }", data: { turbo_frame: "user_collection" } do %>
                Tous les usagers chargés
                <%= render "user_count_badge", user_count: @user_collection.count, active: !user_with_errors? %>
              <% end %>
            </li>
            <li class="nav-item">
              <%= link_to structure_user_list_upload_path(id: @user_list_upload.id, user_with_errors: true), class: "nav-link #{user_with_errors? ? 'active text-dark-blue fw-bold' : 'text-light-blue' }", data: { turbo_frame: "user_collection" } do %>
                Usagers avec erreurs
                <%= render "user_count_badge", user_count: @user_collection.user_rows_with_errors.count, active: user_with_errors? %>
              <% end %>
            </li>
          </ul>
          <div class="d-flex ms-auto">
            <%= render "enrich_with_cnaf_button" %>
            <%= render "search_form" %>
          </div>
        </div>
      </div>
      <%= render "user_rows", user_rows: user_with_errors? ? @user_collection.user_rows_with_errors : @user_collection.user_rows %>
    </div>
  <% end %>

  <div class="d-flex justify-content-between col-md-10 mx-auto px-3 my-5">
    <div>
      <i class="ri-arrow-left-s-line"></i><%= link_to "Revenir à l'étape précédente", new_structure_user_list_upload_path(category_configuration_id: @category_configuration.id), class: "btn btn-link" %>
    </div>
    <div>
      <%= link_to "Créer et mettre à jour les dossiers", structure_user_list_upload_path(id: @user_list_upload.id), class: "btn btn-primary d-block mx-auto", data: { turbo: false } %>
    </div>
  </div>
</div>