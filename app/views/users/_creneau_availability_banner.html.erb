<% period = display_date_period(@latest_creneau_availability.creneaux_available_from, @latest_creneau_availability.creneaux_available_until) %>
<div class="alert alert-info d-flex justify-content-center align-items-center mt-3 mb-1" role="alert">
  <div class="rounded bg-white p-2 d-inline-flex align-items-center gap-2">
    <span class="background-green-light rounded-circle p-1">
      <i class="ri-calendar-line text-dark-green"></i>
    </span>
    <span class="medium text-dark-green">
      <%= @latest_creneau_availability.number_of_creneaux_available %> créneaux disponibles
    </span>
    <span class="text-muted small">
      Calculé le <%= @latest_creneau_availability.created_at.strftime("%d/%m à %Hh%M") %> pour la période <%= period %>
    </span>
  </div>
  <% if (tally_url = ENV["CRENEAU_AVAILABILITY_BANNER_TALLY_URL"]).present? %>
    <% tally_params = { email: current_agent.email,
                        organisation: @organisation.name,
                        department: @department.name } %>
    <div class="position-absolute end-0 d-flex align-items-center gap-3 pe-3">
      <%= link_to "Donnez-nous votre avis", "#{tally_url}?#{tally_params.to_query}",
                  class: "text-underline", target: "_blank" %>
    </div>
  <% end %>
</div>
