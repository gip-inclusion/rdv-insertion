<% in_cooldown = follow_up.in_cooldown_for?(invitation_format) %>
<div id="user-<%= user.id %>-<%= invitation_format %>-invitation">
  <%= form_with(url: structure_user_invitations_path(user_id: user.id), html: { method: :post }, data: { controller: "invitations-checkbox-form", action: "turbo:submit-start->invitations-checkbox-form#submitStart", user_id: user.id, department_id: @department.id, organisation_id: @organisation&.id, invitation_format: invitation_format, follow_up_id: follow_up.id }) do |f| %>
    <%= f.hidden_field :motif_category_id, value: motif_category.id %>
    <%= f.hidden_field :invitation_format, value: invitation_format %>
    <%= button_tag type: "submit", id: "#{invitation_format}_invite_for_user_#{user.id}", class: ["invitation-button", ("invitation-refresh-disabled" if in_cooldown)], data: { action: "click->invitations-checkbox-form#submit" } do %>
      <i class="<%= checked ? "ri-refresh-line" : "ri-checkbox-blank-line" %> invitation-button-icon"></i>
    <% end %>
  <% end %>
</div>
